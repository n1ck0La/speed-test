[Unit]
Description=Speedtest Monitor Web App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/speedtest
ExecStart=%h/speedtest/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
